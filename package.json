{
  "name": "open-learning",
  "version": "1.0.0",
  "description": "Open-source learning platform built with AI",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file=.env packages/bot/src/index.ts",
    "build": "npm run build --workspaces",
    "db:generate": "npm run db:generate --workspace=@open-learning/core",
    "db:migrate": "npm run db:migrate --workspace=@open-learning/core",
    "db:push": "npm run db:push --workspace=@open-learning/core",
    "db:flush": "tsx --env-file=.env scripts/flush-db.ts",
    "db:reset": "tsx --env-file=.env scripts/reset-db.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.13.5",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "marked": "^17.0.5"
  }
}
